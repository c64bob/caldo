package view

templ SyncStatusBadge(state string, lastSuccess string) {
	<section class="flex items-center gap-2" id="sync-status" sse-connect="/events" sse-swap="sync-status">
		<button type="button" class="rounded border border-slate-300 px-3 py-1 text-sm dark:border-slate-700" hx-post="/sync/manual" hx-target="#sync-status" hx-swap="outerHTML">Jetzt synchronisieren</button>
		<p class="text-sm text-slate-600 dark:text-slate-400">Status: { state } · Letzter erfolgreicher Sync: { lastSuccess }</p>
	</section>
}
